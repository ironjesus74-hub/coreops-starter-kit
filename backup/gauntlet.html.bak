<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Atlas Gauntlet — The Arena</title>
  <meta name="description" content="Atlas Gauntlet — where CoreOps tools meet their match in the arena.">

  <!--
    Favicon: self-contained inline SVG data URI — no external file dependency.
    Verified paths: both <link> tags below reference data URIs only,
    so they will never produce a broken 404 request.
  -->
  <link rel="icon" type="image/svg+xml"
        href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Ccircle cx='16' cy='16' r='15' fill='%230d1117' stroke='%2300d4ff' stroke-width='1.5'/%3E%3Cpath d='M16 1A15 15 0 0 0 16 31' fill='none' stroke='%2300d4ff' stroke-width='1.2' opacity='.4'/%3E%3Cpath d='M16 1A15 15 0 0 1 16 31' fill='none' stroke='%23ff2d78' stroke-width='1.2' opacity='.4'/%3E%3Ctext x='16' y='20' text-anchor='middle' fill='%23ffffff' font-family='monospace' font-size='11' font-weight='900'%3EVS%3C/text%3E%3C/svg%3E">
  <link rel="alternate icon" type="image/svg+xml"
        href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Ccircle cx='16' cy='16' r='15' fill='%230d1117' stroke='%2300d4ff' stroke-width='1.5'/%3E%3Ctext x='16' y='20' text-anchor='middle' fill='%23ffffff' font-family='monospace' font-size='11' font-weight='900'%3EVS%3C/text%3E%3C/svg%3E">

  <link rel="stylesheet" href="assets/platform.css">
  <link rel="stylesheet" href="assets/atlas.css">

  <style>
    /* ===== Reset & base ===== */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg-deep:      #080a0e;
      --bg-dark:      #0d1117;
      --bg-card:      #111620;
      --bg-panel:     #161b22;
      --border:       #1e2633;
      --border-sub:   #161c27;
      --cyan:         #00d4ff;
      --cyan-dim:     rgba(0, 212, 255, 0.25);
      --magenta:      #ff2d78;
      --magenta-dim:  rgba(255, 45, 120, 0.25);
      --gold:         #f0a32a;
      --white:        #e6edf3;
      --muted:        #8b949e;
      --faint:        #484f58;
      --radius:       12px;
      --glow-c:       0 0 20px rgba(0, 212, 255, 0.4), 0 0 40px rgba(0, 212, 255, 0.12);
      --glow-m:       0 0 20px rgba(255, 45, 120, 0.4), 0 0 40px rgba(255, 45, 120, 0.12);
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
                   "Liberation Mono", monospace;
      background: var(--bg-deep);
      color: var(--white);
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* ===== Header ===== */
    .header {
      position: relative;
      z-index: 10;
      text-align: center;
      padding: 3rem 2rem 2.5rem;
      border-bottom: 1px solid var(--border);
    }

    .header-badge {
      display: inline-block;
      font-size: 0.6rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--faint);
      border: 1px solid var(--border);
      padding: 0.25rem 0.8rem;
      border-radius: 2em;
      margin-bottom: 1.1rem;
    }

    .header-title {
      font-size: clamp(2rem, 6vw, 4rem);
      font-weight: 800;
      letter-spacing: -0.02em;
      line-height: 1.05;
      margin-bottom: 0.5rem;
      text-shadow: 0 0 40px rgba(0, 212, 255, 0.15);
    }

    .header-title .atlas { color: var(--cyan); }

    .header-sub {
      font-size: 0.72rem;
      color: var(--faint);
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    /* ===== Arena ===== */
    .arena {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      gap: 2.5rem;
      align-items: center;
      padding: 3rem 2rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    /* ===== Competitor cards ===== */
    .card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 2rem;
      transition: border-color 0.3s ease, box-shadow 0.3s ease;
    }

    .card.left  { border-color: rgba(0, 212, 255, 0.2); }
    .card.right { border-color: rgba(255, 45, 120, 0.2); }

    .card.left:hover  { border-color: var(--cyan);    box-shadow: var(--glow-c); }
    .card.right:hover { border-color: var(--magenta); box-shadow: var(--glow-m); }

    .card-badge {
      display: inline-block;
      font-size: 0.58rem;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      padding: 0.2rem 0.65rem;
      border-radius: 2em;
      margin-bottom: 1rem;
    }

    .card.left  .card-badge {
      background: rgba(0, 212, 255, 0.08);
      color: var(--cyan);
      border: 1px solid rgba(0, 212, 255, 0.25);
    }
    .card.right .card-badge {
      background: rgba(255, 45, 120, 0.08);
      color: var(--magenta);
      border: 1px solid rgba(255, 45, 120, 0.25);
    }

    .card-name {
      font-size: 1.4rem;
      font-weight: 700;
      margin-bottom: 0.35rem;
    }

    .card.left  .card-name { color: var(--cyan); }
    .card.right .card-name { color: var(--magenta); }

    .card-tagline {
      font-size: 0.72rem;
      color: var(--muted);
      margin-bottom: 1.5rem;
      letter-spacing: 0.04em;
    }

    /* Stat rows */
    .stats { display: flex; flex-direction: column; gap: 0.8rem; }

    .stat-row {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .stat-label {
      font-size: 0.62rem;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--faint);
      width: 78px;
      flex-shrink: 0;
    }

    .stat-bar-wrap {
      flex: 1;
      height: 3px;
      background: var(--border);
      border-radius: 2px;
      overflow: hidden;
    }

    .stat-bar { height: 100%; border-radius: 2px; }

    .card.left  .stat-bar {
      background: linear-gradient(90deg, var(--cyan-dim), var(--cyan));
    }
    .card.right .stat-bar {
      background: linear-gradient(90deg, var(--magenta-dim), var(--magenta));
    }

    .stat-val {
      font-size: 0.68rem;
      font-weight: 600;
      width: 34px;
      text-align: right;
      flex-shrink: 0;
    }

    .card.left  .stat-val { color: var(--cyan); }
    .card.right .stat-val { color: var(--magenta); }

    /* ===================================================
       VS CORE — Native SVG/CSS component
       No external images, no broken dependencies.
       All visuals are inline SVG + CSS animations.
       =================================================== */
    .vs-wrap {
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      width: 200px;
      height: 200px;
    }

    .vs-svg { width: 100%; height: 100%; overflow: visible; }

    /* Rotation rings */
    @keyframes vs-spin-cw  {
      from { transform: rotate(0deg); }
      to   { transform: rotate(360deg); }
    }
    @keyframes vs-spin-ccw {
      from { transform: rotate(0deg); }
      to   { transform: rotate(-360deg); }
    }

    /* Core pulse */
    @keyframes vs-pulse {
      0%, 100% { opacity: 0.85; }
      50%       { opacity: 1; }
    }

    /* Energy beams */
    @keyframes beam-left {
      0%, 100% { opacity: 0.35; }
      50%       { opacity: 0.9; }
    }
    @keyframes beam-right {
      0%, 100% { opacity: 0.35; }
      50%       { opacity: 0.9; }
    }

    /* Collision sparks */
    @keyframes spark-pop {
      0%   { opacity: 0; r: 1; }
      30%  { opacity: 1; }
      100% { opacity: 0; r: 4; }
    }

    .vs-ring-outer {
      transform-origin: 100px 100px;
      animation: vs-spin-cw 14s linear infinite;
    }
    .vs-ring-inner {
      transform-origin: 100px 100px;
      animation: vs-spin-ccw 9s linear infinite;
    }
    .vs-core-group {
      transform-origin: 100px 100px;
      animation: vs-pulse 2.6s ease-in-out infinite;
    }
    .vs-beam-l { animation: beam-left  2s ease-in-out infinite; }
    .vs-beam-r { animation: beam-right 2s ease-in-out infinite 1s; }

    /* ===== Divider ===== */
    .divider {
      max-width: 1200px;
      margin: 0 auto 2rem;
      padding: 0 2rem;
    }

    .divider-line {
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--border), transparent);
    }

    .divider-label {
      text-align: center;
      margin-top: -0.55rem;
    }

    .divider-label span {
      background: var(--bg-deep);
      padding: 0 0.75rem;
      font-size: 0.58rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--faint);
    }

    /* ===== Battle stats grid ===== */
    .battle-stats {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 2rem 4rem;
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 1rem;
    }

    .stat-tile {
      background: var(--bg-panel);
      border: 1px solid var(--border-sub);
      border-radius: 8px;
      padding: 1.25rem;
      text-align: center;
    }

    .tile-label {
      font-size: 0.58rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--faint);
      margin-bottom: 0.4rem;
    }

    .tile-value {
      font-size: 1.6rem;
      font-weight: 700;
    }

    .tile-value.cyan    { color: var(--cyan); }
    .tile-value.magenta { color: var(--magenta); }
    .tile-value.gold    { color: var(--gold); }

    .tile-sub {
      font-size: 0.58rem;
      color: var(--faint);
      margin-top: 0.2rem;
    }

    /* ===== Footer ===== */
    .footer {
      border-top: 1px solid var(--border);
      padding: 1.5rem 2rem;
      text-align: center;
      font-size: 0.62rem;
      color: var(--faint);
      letter-spacing: 0.1em;
    }

    .footer a { color: var(--faint); text-decoration: none; }
    .footer a:hover { color: var(--cyan); }

    /* ===== Responsive — Tablet ===== */
    @media (max-width: 860px) {
      .arena { gap: 1.5rem; padding: 2.5rem 1.5rem; }
      .vs-wrap { width: 160px; height: 160px; }
    }

    /* ===== Screen-reader only utility ===== */
    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }

    /* ===== Responsive — Mobile ===== */
    @media (max-width: 640px) {
      .arena {
        grid-template-columns: 1fr;
        grid-template-rows: auto auto auto;
        gap: 1.25rem;
        padding: 2rem 1rem;
      }

      /* Stack order: left card → VS → right card */
      .card.left  { grid-row: 1; }
      .vs-wrap    { grid-row: 2; margin: 0 auto; }
      .card.right { grid-row: 3; }

      .vs-wrap { width: 140px; height: 140px; }
      .header  { padding: 2rem 1rem 1.75rem; }
      .battle-stats { padding: 0 1rem 3rem; }
    }

    @media (max-width: 400px) {
      .header-title { font-size: 1.75rem; }
      .card { padding: 1.25rem; }
      .vs-wrap { width: 120px; height: 120px; }
    }
  </style>
</head>
<body>

  <!-- ===== PLATFORM NAV ===== -->
  <nav class="platform-nav" aria-label="Platform sections">
    <ul>
      <li><a href="index.html">Home</a></li>
      <li class="sep" aria-hidden="true">›</li>
      <li><a href="gauntlet.html" aria-current="page">Atlas Gauntlet</a></li>
      <li class="sep" aria-hidden="true">›</li>
      <li><a href="#" aria-disabled="true">Signal Feed</a></li>
      <li class="sep" aria-hidden="true">›</li>
      <li><a href="#" aria-disabled="true">Market</a></li>
      <li class="sep" aria-hidden="true">›</li>
      <li><a href="#" aria-disabled="true">Exchange</a></li>
      <li class="sep" aria-hidden="true">›</li>
      <li><a href="#" aria-disabled="true">Atlas ID</a></li>
    </ul>
  </nav>

  <!-- ===== HEADER ===== -->
  <header class="header">
    <div class="header-badge">Atlas · Season 1 · Open Event</div>
    <h1 class="header-title"><span class="atlas">ATLAS</span> GAUNTLET</h1>
    <p class="header-sub">The Arena · Battle Protocol Active</p>
  </header>

  <!-- ===== MAIN ARENA ===== -->
  <main class="arena" aria-label="Battle Arena">

    <!-- LEFT COMPETITOR -->
    <article class="card left" aria-label="Challenger: CoreOps">
      <span class="card-badge">Challenger</span>
      <h2 class="card-name">CoreOps</h2>
      <p class="card-tagline">Mobile-first DevOps CLI · Termux &amp; Linux</p>
      <div class="stats" aria-label="CoreOps stats">
        <div class="stat-row">
          <span class="stat-label">Speed</span>
          <div class="stat-bar-wrap" role="progressbar" aria-valuenow="92" aria-valuemin="0" aria-valuemax="100">
            <div class="stat-bar" style="width:92%"></div>
          </div>
          <span class="stat-val">92</span>
        </div>
        <div class="stat-row">
          <span class="stat-label">Portability</span>
          <div class="stat-bar-wrap" role="progressbar" aria-valuenow="98" aria-valuemin="0" aria-valuemax="100">
            <div class="stat-bar" style="width:98%"></div>
          </div>
          <span class="stat-val">98</span>
        </div>
        <div class="stat-row">
          <span class="stat-label">Diagnostics</span>
          <div class="stat-bar-wrap" role="progressbar" aria-valuenow="85" aria-valuemin="0" aria-valuemax="100">
            <div class="stat-bar" style="width:85%"></div>
          </div>
          <span class="stat-val">85</span>
        </div>
        <div class="stat-row">
          <span class="stat-label">Resilience</span>
          <div class="stat-bar-wrap" role="progressbar" aria-valuenow="88" aria-valuemin="0" aria-valuemax="100">
            <div class="stat-bar" style="width:88%"></div>
          </div>
          <span class="stat-val">88</span>
        </div>
      </div>
    </article>

    <!--
      ╔══════════════════════════════════════════════════════╗
      ║  VS CORE — Native SVG/CSS component                  ║
      ║  • No external image or asset dependency             ║
      ║  • Fully inline; renders in any browser/context      ║
      ║  • Animated: rotating rings, energy beams, sparks    ║
      ║  • Accessible: role="img" + aria-label on wrapper    ║
      ╚══════════════════════════════════════════════════════╝
    -->
    <div class="vs-wrap" role="img" aria-label="VS — Versus">
      <svg class="vs-svg" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg"
           aria-hidden="true" focusable="false">
        <defs>
          <!-- Cyan beam: fades in from left edge to core center -->
          <linearGradient id="gCyan" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%"   stop-color="#00d4ff" stop-opacity="0"/>
            <stop offset="55%"  stop-color="#00d4ff" stop-opacity="0.85"/>
            <stop offset="100%" stop-color="#00d4ff" stop-opacity="0"/>
          </linearGradient>

          <!-- Magenta beam: fades in from right edge to core center -->
          <linearGradient id="gMag" x1="100%" y1="0%" x2="0%" y2="0%">
            <stop offset="0%"   stop-color="#ff2d78" stop-opacity="0"/>
            <stop offset="55%"  stop-color="#ff2d78" stop-opacity="0.85"/>
            <stop offset="100%" stop-color="#ff2d78" stop-opacity="0"/>
          </linearGradient>

          <!-- Outer ring: cyan-to-magenta sweep -->
          <linearGradient id="gRing" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%"   stop-color="#00d4ff" stop-opacity="0.55"/>
            <stop offset="50%"  stop-color="#ffffff" stop-opacity="0.08"/>
            <stop offset="100%" stop-color="#ff2d78" stop-opacity="0.55"/>
          </linearGradient>

          <!-- Core radial glow (collision bloom) -->
          <radialGradient id="gBloom" cx="50%" cy="50%" r="50%">
            <stop offset="0%"   stop-color="#ffffff"  stop-opacity="0.12"/>
            <stop offset="40%"  stop-color="#f0c040"  stop-opacity="0.06"/>
            <stop offset="100%" stop-color="#080a0e"  stop-opacity="0"/>
          </radialGradient>

          <!-- Clip beam to a horizontal band through the core -->
          <clipPath id="cBeam">
            <rect x="0" y="82" width="200" height="36"/>
          </clipPath>
        </defs>

        <!-- ── Outer rotating dashed ring ── -->
        <g class="vs-ring-outer">
          <circle cx="100" cy="100" r="90"
                  fill="none"
                  stroke="url(#gRing)"
                  stroke-width="1"
                  stroke-dasharray="9 7"
                  opacity="0.65"/>
        </g>

        <!-- ── Inner counter-rotating dual rings ── -->
        <g class="vs-ring-inner">
          <circle cx="100" cy="100" r="76"
                  fill="none"
                  stroke="#00d4ff"
                  stroke-width="0.6"
                  stroke-dasharray="5 14"
                  opacity="0.28"/>
          <circle cx="100" cy="100" r="76"
                  fill="none"
                  stroke="#ff2d78"
                  stroke-width="0.6"
                  stroke-dasharray="5 14"
                  stroke-dashoffset="9"
                  opacity="0.28"/>
        </g>

        <!-- ── Bloom glow (behind beams) ── -->
        <circle cx="100" cy="100" r="48" fill="url(#gBloom)"/>

        <!-- ── Cyan energy beam (from left) ── -->
        <g class="vs-beam-l" clip-path="url(#cBeam)">
          <rect x="0" y="88" width="100" height="24"
                fill="url(#gCyan)" rx="3"/>
          <!-- Thin bright core of the beam -->
          <rect x="0" y="96" width="96" height="8"
                fill="#00d4ff" opacity="0.12" rx="1"/>
        </g>

        <!-- ── Magenta energy beam (from right) ── -->
        <g class="vs-beam-r" clip-path="url(#cBeam)">
          <rect x="100" y="88" width="100" height="24"
                fill="url(#gMag)" rx="3"/>
          <!-- Thin bright core of the beam -->
          <rect x="104" y="96" width="96" height="8"
                fill="#ff2d78" opacity="0.12" rx="1"/>
        </g>

        <!-- ── Core disc ── -->
        <g class="vs-core-group">
          <!-- Outer glow halo -->
          <circle cx="100" cy="100" r="46"
                  fill="none"
                  stroke="#ffffff"
                  stroke-width="0.4"
                  opacity="0.18"/>

          <!-- Core background fill -->
          <circle cx="100" cy="100" r="40" fill="#0d1117"/>

          <!-- Cyan left-arc border -->
          <path d="M100 60 A40 40 0 0 0 100 140"
                fill="none" stroke="#00d4ff" stroke-width="2.5" opacity="0.9"/>

          <!-- Magenta right-arc border -->
          <path d="M100 60 A40 40 0 0 1 100 140"
                fill="none" stroke="#ff2d78" stroke-width="2.5" opacity="0.9"/>

          <!-- VS text — the only text in the component -->
          <text x="100" y="107"
                text-anchor="middle"
                dominant-baseline="middle"
                font-family="ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,monospace"
                font-size="20"
                font-weight="900"
                letter-spacing="2"
                fill="#ffffff">VS</text>
        </g>

        <!-- ── Collision sparks at clash point ── -->
        <circle cx="100" cy="66" r="2" fill="#ffffff" opacity="0">
          <animate attributeName="opacity" values="0;1;0" dur="2.2s" begin="0.3s" repeatCount="indefinite"/>
          <animate attributeName="r"       values="1;3.5;1" dur="2.2s" begin="0.3s" repeatCount="indefinite"/>
        </circle>
        <circle cx="100" cy="134" r="2" fill="#ffffff" opacity="0">
          <animate attributeName="opacity" values="0;1;0" dur="2.2s" begin="1.1s" repeatCount="indefinite"/>
          <animate attributeName="r"       values="1;3.5;1" dur="2.2s" begin="1.1s" repeatCount="indefinite"/>
        </circle>
        <circle cx="76" cy="90" r="1.5" fill="#00d4ff" opacity="0">
          <animate attributeName="opacity" values="0;0.85;0" dur="1.6s" begin="0.6s" repeatCount="indefinite"/>
        </circle>
        <circle cx="124" cy="110" r="1.5" fill="#ff2d78" opacity="0">
          <animate attributeName="opacity" values="0;0.85;0" dur="1.6s" begin="1.4s" repeatCount="indefinite"/>
        </circle>
      </svg>
    </div><!-- /.vs-wrap -->

    <!-- RIGHT COMPETITOR -->
    <article class="card right" aria-label="Defender: Atlas Guard">
      <span class="card-badge">Defender</span>
      <h2 class="card-name">Atlas Guard</h2>
      <p class="card-tagline">Automated repo sentinel · CI/CD shield</p>
      <div class="stats" aria-label="Atlas Guard stats">
        <div class="stat-row">
          <span class="stat-label">Coverage</span>
          <div class="stat-bar-wrap" role="progressbar" aria-valuenow="95" aria-valuemin="0" aria-valuemax="100">
            <div class="stat-bar" style="width:95%"></div>
          </div>
          <span class="stat-val">95</span>
        </div>
        <div class="stat-row">
          <span class="stat-label">Hardening</span>
          <div class="stat-bar-wrap" role="progressbar" aria-valuenow="90" aria-valuemin="0" aria-valuemax="100">
            <div class="stat-bar" style="width:90%"></div>
          </div>
          <span class="stat-val">90</span>
        </div>
        <div class="stat-row">
          <span class="stat-label">Automation</span>
          <div class="stat-bar-wrap" role="progressbar" aria-valuenow="96" aria-valuemin="0" aria-valuemax="100">
            <div class="stat-bar" style="width:96%"></div>
          </div>
          <span class="stat-val">96</span>
        </div>
        <div class="stat-row">
          <span class="stat-label">Visibility</span>
          <div class="stat-bar-wrap" role="progressbar" aria-valuenow="82" aria-valuemin="0" aria-valuemax="100">
            <div class="stat-bar" style="width:82%"></div>
          </div>
          <span class="stat-val">82</span>
        </div>
      </div>
    </article>

  </main><!-- /.arena -->

  <!-- ===== DIVIDER ===== -->
  <div class="divider" role="separator">
    <div class="divider-line"></div>
    <div class="divider-label"><span>Battle Statistics</span></div>
  </div>

  <!-- ===== BATTLE STATS ===== -->
  <section class="battle-stats" aria-labelledby="stats-heading">
    <h2 id="stats-heading" class="sr-only">Battle Statistics</h2>
    <div class="stats-grid">
      <div class="stat-tile">
        <div class="tile-label">Rounds Fought</div>
        <div class="tile-value gold">12</div>
        <div class="tile-sub">Season 1</div>
      </div>
      <div class="stat-tile">
        <div class="tile-label">CoreOps Wins</div>
        <div class="tile-value cyan">7</div>
        <div class="tile-sub">58% win rate</div>
      </div>
      <div class="stat-tile">
        <div class="tile-label">Guard Wins</div>
        <div class="tile-value magenta">5</div>
        <div class="tile-sub">42% win rate</div>
      </div>
      <div class="stat-tile">
        <div class="tile-label">Protocol Status</div>
        <div class="tile-value gold">LIVE</div>
        <div class="tile-sub">ATLAS · Season 1</div>
      </div>
    </div>
  </section>

  <!-- ===== FOOTER ===== -->
  <footer class="footer">
    <a href="https://github.com/ironjesus74-hub/coreops-starter-kit">
      ironjesus74-hub/coreops-starter-kit
    </a>
    &nbsp;·&nbsp; Atlas Gauntlet &nbsp;·&nbsp; Season 1
  </footer>

  <script src="assets/atlas.js" defer></script>
</body>
</html>
