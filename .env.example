# Environment Variables — CoreOps Starter Kit
#
# Copy this file to .env for local development.
# NEVER commit a populated .env file.
#
# Set production secrets via Wrangler:
#   wrangler secret put ATLAS_AI_API_KEY
#   wrangler secret put PAYPAL_CLIENT_ID
#   wrangler secret put PAYPAL_CLIENT_SECRET
#   wrangler secret put PAYPAL_WEBHOOK_ID

# ---------------------------------------------------------------------------
# Atlas AI
# ---------------------------------------------------------------------------
# API key for the Atlas AI backend (OpenAI-compatible)
ATLAS_AI_API_KEY=

# Endpoint for the AI completions API (default: OpenAI)
ATLAS_AI_ENDPOINT=https://api.openai.com/v1/chat/completions

# ---------------------------------------------------------------------------
# PayPal (optional — only required if payments are enabled)
# ---------------------------------------------------------------------------
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# sandbox | live
PAYPAL_ENV=sandbox
