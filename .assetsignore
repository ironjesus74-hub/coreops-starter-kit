# Exclude non-web files from Cloudflare asset serving
# Shell scripts and CLI tools
bin/
bots/
lib/
modules/
install.sh

# CI / tooling
ci/
.github/
.git/

# Config files not meant to be served
wrangler.toml
package.json
package-lock.json
.gitignore
.assetsignore

# Text / docs
*.md
LICENSE
SECURITY.md

# Build artifacts
.wrangler/
node_modules/

# Misc
*.txt
*.backup.*
*.png
audit-demo.png
coreops-live-dashboard.png

# Copilot-pass backup files
*.bak.*
