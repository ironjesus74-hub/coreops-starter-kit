# Exclude non-web files from Cloudflare asset serving
# Shell scripts and CLI tools
bin/
boot/
bots/
lib/
modules/
install.sh
worker/

# Database schema (server-side only)
db/

# CI / tooling
ci/
.github/
.git/

# Config files not meant to be served
wrangler.toml
package.json
package-lock.json
.gitignore
.assetsignore

# Text / docs
*.md
LICENSE
SECURITY.md

# Build artifacts
.wrangler/
node_modules/

# Misc
*.txt
*.backup.*

# Copilot-pass backup files
*.bak.*

# Screenshots served by the site — DO NOT exclude from Cloudflare asset serving
# audit-demo.png              (root — served at /audit-demo.png, used by index.html)
# coreops-live-dashboard.png  (root — served at /coreops-live-dashboard.png, used by OG meta tags on all pages)
# assets/coreops-live-dashboard.png  (assets/ — served at /assets/coreops-live-dashboard.png, used by README)
