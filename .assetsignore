# Exclude non-web files from Cloudflare asset serving
# Shell scripts and CLI tools
bin/
boot/
bots/
lib/
modules/
install.sh
worker/

# CI / tooling
ci/
.github/
.git/

# Config files not meant to be served
wrangler.toml
package.json
package-lock.json
.gitignore
.assetsignore

# Text / docs
*.md
LICENSE
SECURITY.md

# Build artifacts
.wrangler/
node_modules/

# Misc
*.txt
*.backup.*

# Copilot-pass backup files
*.bak.*

# Screenshots served as web assets — DO NOT exclude
# audit-demo.png              (served at /audit-demo.png — displayed on index.html only)
# coreops-live-dashboard.png  (served at /coreops-live-dashboard.png — OG meta image)
# assets/coreops-live-dashboard.png  (served at /assets/coreops-live-dashboard.png — README image)
